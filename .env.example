APP_NAME="MEUS-ARQUIVOS"
APP_URL="http://localhost:3000"
PORT=3000

# Chave para n8n / integracoes externas
APP_API_KEY="troque-por-uma-chave-longa"
JWT_SECRET="troque-por-um-segredo-longo"

# Admin local
ADMIN_EMAIL="admin@meus-arquivos.local"
ADMIN_PASSWORD="troque-esta-senha"

# Armazenamento: local | supabase
STORAGE="local"

# Supabase self-hosted local (quando STORAGE=supabase)
SUPABASE_URL="http://localhost:54321"
SUPABASE_SERVICE_ROLE_KEY=""

# Evolution API local
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_INSTANCE="MEUS-ARQUIVOS"
EVOLUTION_API_KEY="sua-chave-evolution"

# IA opcional
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
